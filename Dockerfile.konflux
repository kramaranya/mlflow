FROM registry.access.redhat.com/ubi9/nodejs-20:9.7 AS ui-builder
WORKDIR /opt/app-root/src
USER 0
RUN npm install -g yarn
COPY --chown=1001:0 mlflow/server/js/ .
USER 1001
ENV MLFLOW_ENABLE_ASSISTANT=false
ENV MLFLOW_ENABLE_AI_GATEWAY=false
RUN yarn install --silent \
    && NODE_OPTIONS="--max_old_space_size=3072" yarn build \
    && NODE_OPTIONS="--max_old_space_size=3072" MLFLOW_API_BASE_URL=/mlflow yarn build:federated

FROM registry.access.redhat.com/ubi9/python-312:9.7 AS python-builder
ARG AIPCC_INDEX_URL=https://console.redhat.com/api/pypi/public-rhai/rhoai/3.4-EA1/cpu-ubi9-test/simple
WORKDIR /src
USER 0
COPY --chown=1001:0 . .
# Unset Cachi2 pip overrides (auto-injected by Konflux) so we can
# fetch from the AIPCC Python package index.
COPY requirements/konflux-build-aipcc.txt /tmp/konflux-build-aipcc.txt
COPY requirements/konflux-pypi.txt /tmp/konflux-pypi.txt
RUN dnf install -y --setopt=tsflags=nodocs postgresql-devel gcc python3.12-devel && \
    unset PIP_NO_INDEX PIP_FIND_LINKS && \
    python -m pip install --no-cache-dir \
        --index-url "$AIPCC_INDEX_URL" \
        -r /tmp/konflux-build-aipcc.txt && \
    rm -f /tmp/konflux-build-aipcc.txt && \
    python -m pip wheel --no-cache-dir --no-deps --require-hashes \
        -r /tmp/konflux-pypi.txt --wheel-dir /tmp/dist && \
    rm -f /tmp/konflux-pypi.txt && \
    cp pyproject.release.toml pyproject.toml && \
    python -m build --wheel --outdir /tmp/dist libs/tracing && \
    python -m build --wheel --outdir /tmp/dist libs/skinny && \
    python -m build --wheel --outdir /tmp/dist . && \
    python -m build --wheel --outdir /tmp/dist kubernetes-workspace-provider

FROM registry.access.redhat.com/ubi9/python-312:9.7
ARG AIPCC_INDEX_URL=https://console.redhat.com/api/pypi/public-rhai/rhoai/3.4-EA1/cpu-ubi9-test/simple
ARG MLFLOW_VERSION=3.3.2
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    MLFLOW_DISABLE_TELEMETRY=true \
    MLFLOW_SERVER_ENABLE_JOB_EXECUTION=false \
    MLFLOW_ENABLE_ASSISTANT=false \
    MLFLOW_ENABLE_AI_GATEWAY=false
WORKDIR /app

USER 0
COPY --from=python-builder /tmp/dist/ /tmp/dist/
COPY requirements/konflux-aipcc.txt /tmp/konflux-aipcc.txt
# Unset Cachi2 pip overrides (auto-injected by Konflux) so we can
# fetch from the AIPCC Python package index first, then re-source
# cachi2.env for the hermetically prefetched extra packages.
RUN set -eux; \
    dnf install -y --setopt=tsflags=nodocs postgresql-libs openblas-threads && \
    unset PIP_NO_INDEX PIP_FIND_LINKS && \
    python -m pip install --no-cache-dir \
        --index-url "$AIPCC_INDEX_URL" \
        -r /tmp/konflux-aipcc.txt && \
    if [ -f /cachi2/cachi2.env ]; then . /cachi2/cachi2.env; fi && \
    python -m pip install --no-cache-dir --no-deps \
        /tmp/dist/mlflow_tracing-*.whl \
        /tmp/dist/mlflow_skinny-*.whl \
        /tmp/dist/mlflow-*.whl \
        /tmp/dist/mlflow_kubernetes_workspace_provider-*.whl \
        /tmp/dist/prometheus_flask_exporter-*.whl \
        /tmp/dist/psycopg2-*.whl && \
    dnf clean all && \
    rm -rf /tmp/dist /tmp/konflux-aipcc.txt

# Copy built UI from builder stage
COPY --from=ui-builder /opt/app-root/src/build /tmp/mlflow-ui-build

RUN set -eux; \
    # Copy the UI build into the installed mlflow package
    py_site=$(python -c 'import sysconfig; print(sysconfig.get_paths()["purelib"])'); \
    mkdir -p "$py_site/mlflow/server/js/build"; \
    rm -rf "$py_site/mlflow/server/js/build"/* || true; \
    cp -r /tmp/mlflow-ui-build/* "$py_site/mlflow/server/js/build/"; \
    rm -rf /tmp/mlflow-ui-build

EXPOSE 5000

# Default command. Override in Kubernetes as needed.
USER 1001
CMD ["mlflow", "server", "--host", "0.0.0.0", "--port", "5000", "--app-name", "kubernetes-auth", "--enable-workspaces", "--workspace-store-uri", "kubernetes://", "--serve-artifacts"]
